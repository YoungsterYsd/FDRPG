# ==============================
# Visual Studio / IDE
# ==============================
.vs/
.vscode/
*.suo
*.sln
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig

# ==============================
# 策划案（非代码资产，不入库）
# ==============================
策划案/

# ==============================
# Compiled Object files
# ==============================
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# Debug symbols
*.pdb

# ==============================
# Xcode (macOS)
# ==============================
*.xcodeproj
*.xcworkspace

# ==============================
# Precompiled Assets (SourceArt)
# ==============================
**/SourceArt/**/*.png
**/SourceArt/**/*.tga

# ==============================
# UE Binary Files
# ==============================
**/Binaries/**
!**/Binaries/**/
**/Plugins/**/Binaries/**

# ==============================
# UE Builds
# ==============================
**/Build/**
!**/Build/*/
**/Build/*/**
!**/Build/*/PakBlacklist*.txt
!**/Build/**/*.ico

# ==============================
# Built data for maps
# ==============================
*_BuiltData.uasset

# ==============================
# UE Saved (Config generated by Editor, Logs, Crashes, etc.)
# ==============================
**/Saved/**

# ==============================
# UE Intermediate (Compiled source files)
# ==============================
**/Intermediate/**
**/Plugins/**/Intermediate/**

# ==============================
# UE DerivedDataCache
# ==============================
**/DerivedDataCache/**

# ==============================
# UE per-user content (local developer collections, etc.)
# ==============================
**/Content/Developers/**
**/Content/Collections/**

# ==============================
# UE Crash reports
# ==============================
**/Crashes/**

# ==============================
# Python cache
# ==============================
__pycache__/
*.pyc

# ==============================
# OS generated files
# ==============================
.DS_Store
Thumbs.db
Desktop.ini
