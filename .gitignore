# ==============================
# Visual Studio / IDE
# ==============================
.vs/
.vscode/
*.suo
*.sln
*.opensdf
*.sdf
*.VC.db
*.VC.opendb
.vsconfig
*.user
*.userprefs

# ==============================
# JetBrains Rider
# ==============================
.idea/
*.iml

# ==============================
# 策划案 / 文档草稿（非代码资产，不入库）
# ==============================
策划案/
配置说明/

# ==============================
# CodeBuddy 数据
# ==============================
.codebuddy/

# ==============================
# LyraStarterGame 参考副本（Day 1 改造后保留作参考，不入库）
# ==============================
LyraStarterGame/

# ==============================
# Day 1~4 改造期的临时脚本与日志（历史价值已随策划案 10/11/13 报告归档，源码树无需保留）
# 一次性脚本统一以 day*_* 命名放在工作区根目录；可复用的工具脚本归 tools/ 入库
# ==============================
/day1_*
/day2_*
/day3_*
/day4_*
/day*_*.ps1
/day*_*.log
/day*_*.txt
/day*_*.ini
/day*_config_backup/

# ==============================
# tools/ 目录：脚本入库，但执行产物不入库
# ==============================
tools/_out/
tools/**/*.log
tools/**/*.err

# ==============================
# Compiled Object files
# ==============================
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# Debug symbols
*.pdb

# ==============================
# Xcode (macOS) —— 本项目不使用 macOS，这里仅防 IDE 误产物
# ==============================
*.xcodeproj
*.xcworkspace

# ==============================
# Precompiled Assets (SourceArt)
# ==============================
**/SourceArt/**/*.png
**/SourceArt/**/*.tga

# ==============================
# UE Binary Files
# ==============================
**/Binaries/**
**/Plugins/**/Binaries/**

# ==============================
# UE Builds（保留 ico 与 PakBlacklist 等少量必要文件）
# ==============================
**/Build/**
!**/Build/**/*.ico
!**/Build/**/PakBlacklist*.txt

# ==============================
# Built data for maps（按需重新生成）
# ==============================
*_BuiltData.uasset

# ==============================
# UE Saved / Intermediate / DDC / Crashes
# ==============================
**/Saved/**
**/Intermediate/**
**/Plugins/**/Intermediate/**
**/DerivedDataCache/**
**/Crashes/**

# ==============================
# UE per-user content
# ==============================
**/Content/Developers/**
**/Content/Collections/**

# ==============================
# Python cache
# ==============================
__pycache__/
*.pyc

# ==============================
# OS generated files
# ==============================
.DS_Store
Thumbs.db
Desktop.ini

# ==============================
# 临时 / 备份文件
# ==============================
*.bak
*.orig
*.tmp
*.swp
*~


# ==============================================================================
# RPG/Content 资产白名单策略
# 仅入库「代码 + 配置类」资产；美术/音频/UI/特效等大体积二进制全部忽略
# 规则：先忽略整个 Content 下所有 .uasset / .umap / 本地化资源，再用 ! 豁免逻辑目录
# ==============================================================================

# 默认忽略所有 uasset / umap / 本地化资源
RPG/Content/**/*.uasset
RPG/Content/**/*.umap
RPG/Content/**/*.po
RPG/Content/**/*.archive
RPG/Content/**/*.locres
RPG/Content/**/*.locmeta
RPG/Content/**/*.ttf
RPG/Content/**/*.tps

# Editor 目录整体不入库（图标/Slate 美术等编辑器资源）
RPG/Content/Editor/

# —— 逻辑类资产豁免（白名单） ——

# 根目录的 GameMode / GameInstance 配置资产
!RPG/Content/B_RPG_*.uasset

# Experience / Team / GameData 等核心系统资产
!RPG/Content/System/
!RPG/Content/System/**
!RPG/Content/System/**/*.uasset

# GameplayEffect 配置
!RPG/Content/GameplayEffects/
!RPG/Content/GameplayEffects/**
!RPG/Content/GameplayEffects/**/*.uasset

# GameplayCue 通知（与战斗逻辑挂钩）
!RPG/Content/GameplayCueNotifies/
!RPG/Content/GameplayCueNotifies/**
!RPG/Content/GameplayCueNotifies/**/*.uasset

# 输入映射 / InputAction / InputConfig
!RPG/Content/Input/
!RPG/Content/Input/**
!RPG/Content/Input/**/*.uasset

# 关卡（玩法承载，体积小）
!RPG/Content/Maps/
!RPG/Content/Maps/**
!RPG/Content/Maps/**/*.umap
!RPG/Content/Maps/**/*.uasset

# ==============================================================================
# 显式忽略：示例 / 美术 / 大体积内容插件
# ==============================================================================

# Lyra 示例内容插件（整目录不入库）
RPG/Plugins/LyraExampleContent/

# 角色美术资源（保留旧规则；目前 Content/Characters 已被白名单策略统一忽略）
**/Content/Character/**
